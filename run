#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")"

# Load env
if [ -f .env ]; then
  set -a
  source .env
  set +a
fi

API_PORT="${API_PORT:-3000}"
DASHBOARD_PORT="${DASHBOARD_PORT:-5173}"

echo ""
echo "  ████████████████████████████████████████████"
echo "  █  brAIn                                   █"
echo "  █  API:       http://localhost:${API_PORT}         █"
echo "  █  Dashboard: http://localhost:${DASHBOARD_PORT}         █"
echo "  ████████████████████████████████████████████"
echo ""

exec pnpm start
